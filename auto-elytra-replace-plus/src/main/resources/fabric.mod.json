{
  "schemaVersion": 1,
  "id": "auto-elytra-replace-plus",
  "version": "${version}",
  "name": "AutoElytraReplacePlus",
  "description": "Automatically replaces low-durability elytra from your inventory.",
  "authors": ["tuoaddon"],
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.tuoaddon.AutoElytraAddon"
    ]
  },
  "custom": {
    "meteor-client:color": "80,200,255",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
